---
import { Icon } from "astro-icon/components";
import CurrentIPLine from "@/components/CurrentIPLine.astro";
import MainCard from "@/components/MainCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

/**
 * Featured Song Config
 */
const FEATURED_SONG_UPDATED_AT_UTC8 = "Mar 27, 2026";

const APPLE_MUSIC_EMBED_URL =
  "https://embed.music.apple.com/cn/song/%E4%B8%8D%E6%AD%BB%E4%B9%8B%E8%BA%AB/1071513025";

const featuredSong = {
  sectionTitle: "限时歌曲推介 / Song Recommendation",
  songName: "不死之身",
  artist: "林俊杰 (JJ Lin)",
  note: "Apple Music 播放",
  appleMusicLink:
    "https://music.apple.com/cn/song/%E4%B8%8D%E6%AD%BB%E4%B9%8B%E8%BA%AB/1071513025",
};
---


<BaseLayout title="Home">
  <MainCard
    title="欢迎访问 Kumo 的个人博客"
    description="侬饭切了伐？"
    textOverlay="侬好"
    infoIcon="lucide:info"
  >
    <div class="space-y-8">
      <!-- Hero Section -->
      <section class="py-6">
        <div class="flex flex-col items-center text-center">
          <h1
            class="text-4xl font-bold mb-4 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent leading-loose"
          >
            🌟 Kumo's Blog
          </h1>
          <div class="max-w-3xl w-full mb-8"><CurrentIPLine /></div>
          <div class="flex flex-wrap gap-4 justify-center">
            <a href="/blog" class="btn btn-primary gap-2 btn-shine-effect">
              <Icon name="lucide:book-open" class="w-5 h-5" />
              <span>探索博客</span>
            </a>
            <a href="https://github.com/KumoMayu" target="_blank" class="btn btn-outline gap-2">
              <Icon name="lucide:github" class="w-5 h-5" />
              <span>我的 Github 项目</span>
            </a>
          </div>
        </div>
      </section>

      <!-- Featured Song (Apple Music Embed) -->
       
      <h2 class="text-2xl font-bold mb-6 flex items-center justify-between gap-2">
        <span class="flex items-center gap-2">
          <Icon name="lucide:music" class="w-6 h-6 text-primary" />
          <span>{featuredSong.sectionTitle}</span>
        </span>

        <span class="text-sm text-base-content/60">
          更新时间 / Updated: 
          <span class="font-medium">{FEATURED_SONG_UPDATED_AT_UTC8}</span>
        </span>
      </h2>


      <script is:inline>
        const el = document.getElementById("song-updated");
        if (el) {
          const s = new Intl.DateTimeFormat("zh-CN", {
            timeZone: "Asia/Shanghai",
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            hour: "2-digit",
            minute: "2-digit",
            hour12: false,
          }).format(new Date());
          el.textContent = s;
        }
      </script>
        <div class="card bg-base-200 p-6 shadow-md">
          <div class="flex flex-col gap-4">
            <!-- Text row -->
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div>
                <p class="text-sm text-base-content/60">{featuredSong.note}</p>
                <h3 class="text-xl font-bold leading-snug">{featuredSong.songName}</h3>
                <p class="text-base-content/70">{featuredSong.artist}</p>
              </div>

              <a
                class="btn btn-primary gap-2"
                href={featuredSong.appleMusicLink}
                target="_blank"
                rel="noreferrer"
              >
                <Icon name="lucide:external-link" class="w-5 h-5" />
                <span>在 Apple Music 上打开</span>
              </a>
            </div>

            <!-- Player -->
            <div class="bg-base-100/60 rounded-xl p-3">
              <iframe
                title="Apple Music Player"
                allow="autoplay *; encrypted-media *; fullscreen *; clipboard-write"
                frameborder="0"
                height="175"
                style="width:100%; max-width:100%; overflow:hidden; border-radius:12px;"
                sandbox="allow-forms allow-popups allow-same-origin allow-scripts allow-top-navigation-by-user-activation"
                src={APPLE_MUSIC_EMBED_URL}
              ></iframe>

              <div class="alert bg-base-100/60 mt-3">
                <Icon name="lucide:info" class="w-5 h-5" />
                <span class="text-sm">
                  提示：稍等一会链接即可呈现~多数浏览器不允许“自动播放有声音的音乐”，需要你先点一次播放键。
                </span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- GitHub Stats -->
      <section class="py-6">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:github" class="w-6 h-6 text-primary" />
          <span>项目数据看板 / Project Data</span>
        </h2>

        <GitHubStats username="KumoMayu" repositoryName="kumo-s-blog" showLanguages={true} showContributors={true} />
      </section>
    </div>
  </MainCard>
</BaseLayout>
